# PostgreSQL local
POSTGRES_DB=cervecerdas
POSTGRES_USER=cervecerdas
POSTGRES_PASSWORD=change-me-locally
POSTGRES_PORT=5432
DATABASE_URL=postgresql://cervecerdas:change-me-locally@localhost:5432/cervecerdas

# Auth.js. Genera uno nuevo con: openssl rand -base64 32
AUTH_SECRET=replace-with-at-least-32-random-characters
NEXTAUTH_URL=http://localhost:3000
SESSION_MAX_AGE_SECONDS=604800

# Puerto publicado por Docker Compose
APP_PORT=3000
